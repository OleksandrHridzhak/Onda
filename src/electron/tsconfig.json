{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "lib": ["ES2022"],
        "types": ["node"],
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "noEmit": false
    },
    "include": ["main/**/*.ts", "preload/**/*.ts", "ipc/**/*.ts"]
}
